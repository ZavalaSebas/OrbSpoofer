<Window x:Class="OrbSpoofer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OrbSpoofer"
        Title="OrbSpoofer" Height="700" Width="1000"
        MinHeight="600" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="OS.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="OS.png" Width="32" Height="32" Margin="0,0,12,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OrbSpoofer" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" FontFamily="{StaticResource HeaderFont}"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" FontFamily="{StaticResource BodyFont}">
                            <Run Text="Discord Orb Quest Spoofer"/>
                            <Run Text=" · " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run x:Name="HeaderStatusText" Text="Loading..." Foreground="{StaticResource WarningBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionText" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="12,16">
                    <TextBlock Text="M  O  D  E  S" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,12"
                               FontFamily="{StaticResource BodyFont}"/>

                    <Button x:Name="BtnQuests" Content="🏆  Active Quests"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Click="BtnQuests_Click"/>

                    <Button x:Name="BtnDatabase" Content="🔍  Discord Database"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Click="BtnDatabase_Click"/>
                    <Button x:Name="BtnManual" Content="✏️  Manual Mode"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Click="BtnManual_Click"/>
                    <Button x:Name="BtnSteam" Content="🎮  Steam Quest"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Click="BtnSteam_Click"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12,0,12"/>

                    <TextBlock Text="I  N  F  O" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="8,0,0,12"
                               FontFamily="{StaticResource BodyFont}"/>

                    <Button x:Name="BtnCredits" Content="ℹ️  Credits &amp; Info"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Click="BtnCredits_Click"/>

                    <Button x:Name="BtnUpdateReminder" Content="⬆  Update Available"
                            Style="{StaticResource GhostButton}"
                            HorizontalContentAlignment="Left" Margin="0,0,0,6"
                            Visibility="Collapsed"
                            Foreground="{StaticResource WarningBrush}"
                            Click="UpdateReminder_Click"/>

                    <Separator Background="{StaticResource BorderBrush}" Margin="0,12,0,12"/>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="28,24">

                <!-- Loading State -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:Name="LoadingText" Text="Loading..."
                               FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="LoadingProgress" Width="200" Height="4" Margin="0,16,0,0"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource BorderBrush}"
                                 IsIndeterminate="True" BorderThickness="0"/>
                </StackPanel>

                <!-- Database Search View -->
                <Grid x:Name="DatabaseView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Discord Database" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" Margin="0,28,0,0">
                        <Run x:Name="DbSourceText" Text=""/>
                    </TextBlock>

                    <Grid Grid.Row="1" Margin="0,16,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                 Style="{StaticResource SearchBox}"
                                 
                                 KeyDown="SearchBox_KeyDown"
                                 TextChanged="SearchBox_TextChanged"
                                 VerticalContentAlignment="Center"/>
                        <Button x:Name="BtnSearch" Grid.Column="1" Content="Search"
                                Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                Click="BtnSearch_Click"/>
                    </Grid>

                    <ListBox x:Name="ResultsList" Grid.Row="2"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ResultsList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                 <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                         Padding="16" Margin="0,0,0,6"
                                         ToolTip="Double-click to spoof">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <Border Grid.Column="0" Width="92" Height="48" CornerRadius="8"
                                                 Background="{StaticResource SurfaceBrush}"
                                                 Margin="0,0,14,0">
                                             <Grid>
                                                 <TextBlock Text="🎮" FontSize="20"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                 <Image Source="{Binding ImageUrl}" Width="92" Height="48"
                                                        Stretch="Uniform"
                                                        RenderOptions.BitmapScalingMode="HighQuality"/>
                                             </Grid>
                                         </Border>
                                         <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                             <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                                             <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                        Margin="0,4,0,0">
                                                 <Run Text="ID: "/>
                                                 <Run Text="{Binding Id, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}"/>
                                             </TextBlock>
                                             <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                        Margin="0,2,0,0" Text="{Binding AliasDisplay}"/>
                                         </StackPanel>
                                         <Button Grid.Column="2" Content="▶"
                                                 Style="{StaticResource PrimaryButton}"
                                                 Padding="8" Width="60" Height="60"
                                                 FontSize="24"
                                                 Tag="{Binding}"
                                                 ToolTip="Spoof"
                                                 Click="SpoofGame_Click"/>
                                     </Grid>
                                 </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="NoResultsText" Grid.Row="2"
                               Text="Type the game name and click ▶ to spoof"
                               FontSize="15" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Visible"/>
                </Grid>

                <!-- Manual Mode View -->
                <Grid x:Name="ManualView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Manual Mode" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" Margin="0,28,0,0"
                               Text="Enter the exact process name Discord expects"/>

                    <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="10"
                            Padding="16" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Examples:" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,4" Text="• TslGame.exe (PUBG)"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,0,4" Text="• League of Legends.exe (LoL)"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                       Text="• Overwatch.exe"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ManualExeBox" Grid.Column="0"
                                 Style="{StaticResource ManualInputBox}"
                                 TextChanged="ManualExeBox_TextChanged"
                                 VerticalContentAlignment="Center"/>
                         <Button x:Name="BtnManualSpoof" Grid.Column="1" Content="▶"
                                 Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                 Padding="8" Width="60" Height="60" FontSize="24"
                                 ToolTip="Spoof"
                                 IsEnabled="False"
                                 Click="BtnManualSpoof_Click"/>
                    </Grid>

                    <Border x:Name="ManualResultPanel" Grid.Row="3" Visibility="Collapsed"
                            Background="{StaticResource CardBrush}" CornerRadius="10"
                            Padding="16" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock x:Name="ManualResultText" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Steam Quest View -->
                <Grid x:Name="SteamView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Steam Quest Mode" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" Margin="0,28,0,0"
                               Text="Generates a fake Steam appmanifest for games that verify Steam ownership"/>

                    <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="10"
                            Padding="14" Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Steam:" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock x:Name="SteamPathText" Grid.Column="1" Text="Detecting..."
                                       FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SteamSearchBox" Grid.Column="0"
                                 Style="{StaticResource SearchBox}"
                                 
                                 KeyDown="SteamSearchBox_KeyDown"
                                 TextChanged="SteamSearchBox_TextChanged"
                                 VerticalContentAlignment="Center"/>
                        <Button x:Name="BtnSteamSearch" Grid.Column="1" Content="Search"
                                Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                Click="BtnSteamSearch_Click"/>
                    </Grid>

                    <ListBox x:Name="SteamResultsList" Grid.Row="3"
                             Background="Transparent" BorderThickness="0"
                             Margin="0,12,0,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="SteamResultsList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                 <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                                         Padding="16" Margin="0,0,0,6"
                                         ToolTip="Double-click to spoof">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <Border Grid.Column="0" Width="92" Height="48" CornerRadius="8"
                                                 Background="{StaticResource SurfaceBrush}"
                                                 Margin="0,0,14,0">
                                             <Image Source="{Binding ImageUrl}" Width="92" Height="48"
                                                    Stretch="Uniform"
                                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                                         </Border>
                                         <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                             <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                                             <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                        Margin="0,4,0,0">
                                                 <Run Text="AppID: "/>
                                                 <Run Text="{Binding Id, Mode=OneWay}"/>
                                             </TextBlock>
                                         </StackPanel>
                                           <Button Grid.Column="2" Content="▶"
                                                   Style="{StaticResource PrimaryButton}"
                                                   Padding="8" Width="60" Height="60"
                                                   FontSize="24"
                                                   Tag="{Binding}"
                                                   ToolTip="Spoof"
                                                   Click="SteamSpoof_Click"/>
                                      </Grid>
                                  </Border>
                             </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="SteamNoResultsText" Grid.Row="3"
                               Text="Search a Steam game and click ▶ to spoof"
                               FontSize="15" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Quests View -->
                <Grid x:Name="QuestsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Active Quests" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource OrangeBrush}" Margin="0,0,0,16">
                        <Run Text="Quests vary by region and availability. "/>
                        <Run Text="If there's nothing here, switch to Database mode and type the game name."/>
                    </TextBlock>

                    <TextBlock x:Name="QuestsLoadingText" Grid.Row="2" Text="Loading quests..."
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="QuestsEmptyText" Grid.Row="2"
                               FontSize="14" Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <ListBox x:Name="QuestsList" Grid.Row="2"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border" Background="Transparent" Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                 <Border Background="{StaticResource CardBrush}" CornerRadius="12"
                                         Padding="16" Margin="0,0,0,10"
                                         ToolTip="Double-click to spoof">
                                     <Border.Style>
                                         <Style TargetType="Border">
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                     <Setter Property="Opacity" Value="0.45"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Border.Style>
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>

                                         <Border Grid.Column="0" Width="64" Height="64" CornerRadius="8"
                                                 Background="{StaticResource SurfaceBrush}"
                                                 Margin="0,0,14,0">
                                             <Image Source="{Binding ImageUrl}" Width="64" Height="64"
                                                    Stretch="UniformToFill"
                                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                                         </Border>

                                         <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                             <TextBlock Text="{Binding GameName}" FontSize="15" FontWeight="SemiBold"
                                                        Foreground="{StaticResource TextPrimaryBrush}">
                                                 <TextBlock.Style>
                                                     <Style TargetType="TextBlock">
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                 <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </TextBlock.Style>
                                             </TextBlock>
                                             <TextBlock Text="{Binding QuestName}" FontSize="12"
                                                        Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                 <TextBlock.Style>
                                                     <Style TargetType="TextBlock">
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                 <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </TextBlock.Style>
                                             </TextBlock>
                                             <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                 <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                                     <Run Text="{Binding Reward, Mode=OneWay}"/>
                                                 </TextBlock>
                                                 <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                            Margin="12,0,0,0">
                                                     <Run Text="{Binding TaskMinutes, Mode=OneWay}"/>
                                                     <Run Text=" min"/>
                                                 </TextBlock>
                                                 <TextBlock FontSize="11" Foreground="{StaticResource WarningBrush}"
                                                            Margin="12,0,0,0">
                                                     <Run Text="Ends "/>
                                                     <Run Text="{Binding ExpiresAt, Mode=OneWay, StringFormat={}{0:MMM d}}"/>
                                                 </TextBlock>
                                                 <TextBlock FontSize="11" Foreground="{StaticResource WarningBrush}"
                                                            Margin="12,0,0,0">
                                                     <TextBlock.Style>
                                                         <Style TargetType="TextBlock">
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding NeedsSteamMode}" Value="True">
                                                                     <Setter Property="Visibility" Value="Visible"/>
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                             <Setter Property="Visibility" Value="Collapsed"/>
                                                         </Style>
                                                     </TextBlock.Style>
                                                     <Run Text="⚠ Steam required"/>
                                                 </TextBlock>
                                             </StackPanel>
                                         </StackPanel>

                                         <Border Grid.Column="2" Width="32" Height="32"
                                                 CornerRadius="16" Cursor="Hand" Tag="{Binding}"
                                                 ToolTip="Toggle completed"
                                                 BorderThickness="1.5"
                                                 Background="{StaticResource SurfaceBrush}"
                                                 BorderBrush="{StaticResource TextMutedBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"
                                                 PreviewMouseLeftButtonDown="QuestCompleteToggle_Click">
                                             <Border.Style>
                                                 <Style TargetType="Border">
                                                     <Style.Triggers>
                                                         <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                             <Setter Property="Background" Value="#4CAF50"/>
                                                             <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                         </DataTrigger>
                                                     </Style.Triggers>
                                                 </Style>
                                             </Border.Style>
                                             <TextBlock Text="✓" FontSize="14" FontWeight="Bold"
                                                        Foreground="White" HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                 <TextBlock.Style>
                                                     <Style TargetType="TextBlock">
                                                         <Setter Property="Visibility" Value="Hidden"/>
                                                         <Style.Triggers>
                                                             <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </DataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </TextBlock.Style>
                                             </TextBlock>
                                         </Border>

                                         <Button Grid.Column="3" Content="▶"
                                                 Style="{StaticResource PrimaryButton}"
                                                  Padding="8" Width="60" Height="60"
                                                  FontSize="24"
                                                  Tag="{Binding}"
                                                  ToolTip="Spoof"
                                                 Click="QuestsSpoof_Click"/>
                                     </Grid>
                                 </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Credits View -->
                <Grid x:Name="CreditsView" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,8">
                            <TextBlock Text="Credits &amp; Info" FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                            <Border x:Name="CreditAbout" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="About" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                                        OrbSpoofer is a game process spoofer that tricks Discord into thinking
                                        you're running a game by creating fake processes with the exact names
                                        Discord expects. No client modification. No code injection.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CreditHowItWorks" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="How it works" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                                        <Run>1. Your active Discord quests appear automatically on launch</Run>
                                        <LineBreak/>
                                        <Run>2. Double-click a quest or press ▶ to start spoofing</Run>
                                        <LineBreak/>
                                        <Run>3. OrbSpoofer finds the exact process name Discord expects</Run>
                                        <LineBreak/>
                                        <Run>4. Copies the app executable and renames it to match</Run>
                                        <LineBreak/>
                                        <Run>5. Launches the fake process in background</Run>
                                        <LineBreak/>
                                        <Run>6. Discord scans running processes and detects the fake process</Run>
                                        <LineBreak/>
                                        <Run>7. Discord thinks you're playing the game</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CreditSteam" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Steam Quest Mode" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                                        Some games (Marathon, Toxic Commando...) require Discord to verify
                                        that Steam has partially downloaded them. This mode generates a fake
                                        appmanifest and places the executable in the correct Steam directory.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CreditDisclaimer" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⚠ Disclaimer" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource WarningBrush}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                                        OrbSpoofer is a Discord automation tool built for educational
                                        purposes. It automates a manual process using Discord's public
                                        API and process detection. You are solely responsible for
                                        complying with Discord's Terms of Service. Use at your own risk.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CreditSupport" Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="❤ Support" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22"
                                               Margin="0,0,0,14">
                                        Enjoying OrbSpoofer? Your support keeps the project alive!
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Buy me a coffee ☕"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,8" FontSize="13" Cursor="Hand"
                                                Click="Kofi_Click"/>
                                        <Button Grid.Column="2" Content="GitHub Sponsor ❤"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,8" FontSize="13" Cursor="Hand"
                                                Foreground="{StaticResource ErrorBrush}"
                                                BorderBrush="{StaticResource ErrorBrush}"
                                                 Click="GitHubSponsor_Click"/>
                                        </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="0,16,0,4">
                                <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}">
                                    <Run Text="Original concept by "/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                           Cursor="Hand" MouseLeftButtonDown="Strykey_Click"
                                           Text="Strykey" Margin="0,0,0,0"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                           Text=" · "/>
                                <TextBlock FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                           Cursor="Hand" MouseLeftButtonDown="Orbshacker_Click"
                                           Text="orbshacker"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Cursor="Hand" MouseLeftButtonDown="GitHubProfile_Click">
                                <Run Text="Made with love by "/>
                                <Run Text="ZavalaSebas" Foreground="{StaticResource PrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusMessage" Text="Ready"
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="GameCount" Text=""
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="❤" FontSize="14" Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center" Margin="14,0,0,0" Cursor="Hand"
                               ToolTip="Enjoying OrbSpoofer? Buy me a coffee!"
                               MouseLeftButtonDown="Kofi_HeartClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
