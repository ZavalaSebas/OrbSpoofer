<Window x:Class="OrbSpoofer.UI.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanks for downloading OrbSpoofer" Height="520" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="/OrbSpoofer;component/OS.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border x:Name="HeaderBorder" Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="28,16">
            <StackPanel Orientation="Horizontal">
                <Image Source="/OrbSpoofer;component/OS.png" Width="36" Height="36"
                       Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Thanks for downloading OrbSpoofer!"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Discord Orb Quest Spoofer" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,0">

                <Border x:Name="CardWhatsNew" Background="{StaticResource CardBrush}" CornerRadius="10"
                        Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="WhatsNewHeader" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel x:Name="WhatsNewItems"/>
                    </StackPanel>
                </Border>

                <Border x:Name="CardHowItWorks" Background="{StaticResource CardBrush}" CornerRadius="10"
                        Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                    <TextBlock Text="How it works" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" LineHeight="20">
                            Your active Discord quests appear automatically on launch.
                            Double-click a quest or press ▶ to start spoofing.
                            No quests? Switch to Database or Steam mode to search manually.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border x:Name="CardSupport" Background="{StaticResource CardBrush}" CornerRadius="10"
                        Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Support the project" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="18"
                                   Margin="0,0,0,10">
                            OrbSpoofer is free and open-source. Your support keeps the project alive!
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Buy me a coffee ☕"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,6" FontSize="12" Cursor="Hand"
                                    Click="Kofi_Click"/>
                            <Button Grid.Column="2" Content="GitHub Sponsor ❤"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="12" Cursor="Hand"
                                    Foreground="{StaticResource ErrorBrush}"
                                    BorderBrush="{StaticResource ErrorBrush}"
                                    Click="GitHubSponsor_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border x:Name="FooterBorder" Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="DontShowAgainCheck" Grid.Column="0"
                          IsChecked="True"
                          Content="Don't show again"
                          FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                          VerticalAlignment="Center"/>

                <Button x:Name="BtnGetStarted" Grid.Column="2" Content="Get Started"
                        Style="{StaticResource PrimaryButton}"
                        Padding="20,8" FontSize="13"
                        Click="GetStarted_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
