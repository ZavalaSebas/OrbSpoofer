<Window x:Class="OrbSpoofer.UI.Windows.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" Height="300" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="/OrbSpoofer;component/OS.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <Image Source="/OrbSpoofer;component/OS.png" Width="32" Height="32"
                       Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Update Available" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock x:Name="VersionText" Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,0">

            <TextBlock TextWrapping="Wrap" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20"
                       Margin="0,0,0,16">
                A new version of OrbSpoofer is ready to install. Would you like to download it now?
            </TextBlock>

            <!-- Progress -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,0">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Downloading..."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="ProgressText" Grid.Column="1" Text="0%"
                               FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"/>
                </Grid>
                <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="{StaticResource BorderBrush}" BorderThickness="0"/>
            </StackPanel>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SkipBtn" Grid.Column="0" Content="Skip"
                        Style="{StaticResource GhostButton}"
                        Padding="20,8" FontSize="12" Cursor="Hand"
                        Click="Skip_Click"/>

                <Button x:Name="UpdateBtn" Grid.Column="2" Content="Update Now"
                        Style="{StaticResource PrimaryButton}"
                        Padding="20,8" FontSize="12" Cursor="Hand"
                        Click="UpdateNow_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
